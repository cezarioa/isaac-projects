#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "World"
{
    def Xform "Environment"
    {
        def Scope "Looks"
        {
            def Material "mat_wall_light_gray"
            {
                token outputs:surface.connect = </World/Environment/Looks/mat_wall_light_gray/PBRShader.outputs:surface>
                def Shader "PBRShader"
                {
                    uniform token info:id = "UsdPreviewSurface"
                    color3f inputs:diffuseColor = (0.78, 0.82, 0.82)
                    float inputs:roughness = 0.65
                    token outputs:surface
                }
            }

            def Material "mat_floor_gray_wood"
            {
                token outputs:surface.connect = </World/Environment/Looks/mat_floor_gray_wood/PBRShader.outputs:surface>
                def Shader "PBRShader"
                {
                    uniform token info:id = "UsdPreviewSurface"
                    color3f inputs:diffuseColor = (0.48, 0.52, 0.50)
                    float inputs:roughness = 0.75
                    token outputs:surface
                }
            }

            def Material "mat_white_furniture"
            {
                token outputs:surface.connect = </World/Environment/Looks/mat_white_furniture/PBRShader.outputs:surface>
                def Shader "PBRShader"
                {
                    uniform token info:id = "UsdPreviewSurface"
                    color3f inputs:diffuseColor = (0.94, 0.94, 0.90)
                    float inputs:roughness = 0.48
                    token outputs:surface
                }
            }

            def Material "mat_black_plastic"
            {
                token outputs:surface.connect = </World/Environment/Looks/mat_black_plastic/PBRShader.outputs:surface>
                def Shader "PBRShader"
                {
                    uniform token info:id = "UsdPreviewSurface"
                    color3f inputs:diffuseColor = (0.015, 0.015, 0.014)
                    float inputs:roughness = 0.42
                    token outputs:surface
                }
            }

            def Material "mat_gray_metal"
            {
                token outputs:surface.connect = </World/Environment/Looks/mat_gray_metal/PBRShader.outputs:surface>
                def Shader "PBRShader"
                {
                    uniform token info:id = "UsdPreviewSurface"
                    color3f inputs:diffuseColor = (0.45, 0.50, 0.52)
                    float inputs:roughness = 0.35
                    float inputs:metallic = 0.2
                    token outputs:surface
                }
            }

            def Material "mat_green_plant"
            {
                token outputs:surface.connect = </World/Environment/Looks/mat_green_plant/PBRShader.outputs:surface>
                def Shader "PBRShader"
                {
                    uniform token info:id = "UsdPreviewSurface"
                    color3f inputs:diffuseColor = (0.06, 0.28, 0.04)
                    float inputs:roughness = 0.8
                    token outputs:surface
                }
            }

            def Material "mat_blue"
            {
                token outputs:surface.connect = </World/Environment/Looks/mat_blue/PBRShader.outputs:surface>
                def Shader "PBRShader"
                {
                    uniform token info:id = "UsdPreviewSurface"
                    color3f inputs:diffuseColor = (0.02, 0.38, 0.85)
                    float inputs:roughness = 0.55
                    token outputs:surface
                }
            }

            def Material "mat_colorful"
            {
                token outputs:surface.connect = </World/Environment/Looks/mat_colorful/PBRShader.outputs:surface>
                def Shader "PBRShader"
                {
                    uniform token info:id = "UsdPreviewSurface"
                    color3f inputs:diffuseColor = (0.95, 0.12, 0.10)
                    float inputs:roughness = 0.55
                    token outputs:surface
                }
            }
        }

        def Xform "room_static"
        {
            def Cube "Floor"
            {
                double3 xformOp:scale = (3.8, 3.0, 0.04)
                double3 xformOp:translate = (0, 0, -0.02)
                uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                rel material:binding = </World/Environment/Looks/mat_floor_gray_wood>
            }

            def Cube "BackWall"
            {
                double3 xformOp:scale = (3.8, 0.05, 1.35)
                double3 xformOp:translate = (0, 3.0, 1.35)
                uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                rel material:binding = </World/Environment/Looks/mat_wall_light_gray>
            }

            def Cube "RightWall"
            {
                double3 xformOp:scale = (0.05, 3.0, 1.35)
                double3 xformOp:translate = (3.8, 0, 1.35)
                uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                rel material:binding = </World/Environment/Looks/mat_wall_light_gray>
            }

            def Cube "LeftLowCabinet_WallSide"
            {
                double3 xformOp:scale = (0.95, 0.28, 0.42)
                double3 xformOp:translate = (-2.8, 2.65, 0.42)
                uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                rel material:binding = </World/Environment/Looks/mat_white_furniture>
