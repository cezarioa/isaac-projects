            def Xform "PlantCluster"
            {
                double3 xformOp:translate = (-1.5, 2.25, 0.72)
                uniform token[] xformOpOrder = ["xformOp:translate"]
                def Cylinder "GrassBlade_01"
                {
                    double radius = 0.012
