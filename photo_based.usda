                    double3 xformOp:translate = (0.95, 0.05, 0.16)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                    rel material:binding = </World/Environment/Looks/mat_black_plastic>
                }
                def Cube "HeartModelStand"
                {
                    double3 xformOp:scale = (0.18, 0.12, 0.04)
                    double3 xformOp:translate = (1.35, 0.30, 0.04)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                    rel material:binding = </World/Environment/Looks/mat_white_furniture>
                }
            }

            def Xform "MobileCart"
            {
                double3 xformOp:translate = (-1.05, -0.45, 0.48)
                uniform token[] xformOpOrder = ["xformOp:translate"]
                def Cube "Crate"
                {
                    double3 xformOp:scale = (0.50, 0.38, 0.30)
                    double3 xformOp:translate = (0, 0, 0.05)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                    rel material:binding = </World/Environment/Looks/mat_gray_metal>
