                    double3 xformOp:rotateXYZ = (-12, 0, -6)
                    double3 xformOp:translate = (0.05, 0.05, 0.72)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
                    rel material:binding = </World/Environment/Looks/mat_green_plant>
                }
                def Cylinder "GrassBlade_03"
                {
                    double radius = 0.012
                    double height = 1.55
                    double3 xformOp:rotateXYZ = (8, 0, 18)
                    double3 xformOp:translate = (0.22, -0.04, 0.70)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
                    rel material:binding = </World/Environment/Looks/mat_green_plant>
                }
            }
        }
    }

    def Xform "Robots"
    {
        def Xform "HumanoidPlaceholder"
        {
            double3 xformOp:translate = (-1.15, 0.85, 0.85)
            uniform token[] xformOpOrder = ["xformOp:translate"]
            def Capsule "Torso"
            {
                double radius = 0.22
                double height = 0.45
                rel material:binding = </World/Environment/Looks/mat_white_furniture>
            }
            def Sphere "Head"
            {
                double radius = 0.18
                double3 xformOp:translate = (0, 0, 0.48)
                uniform token[] xformOpOrder = ["xformOp:translate"]
                rel material:binding = </World/Environment/Looks/mat_black_plastic>
            }
        }
    }

    def Xform "Lights"
    {
        def DistantLight "Sun"
        {
            float inputs:angle = 0.45
            float inputs:intensity = 550
            double3 xformOp:rotateXYZ = (-45, 0, 35)
            uniform token[] xformOpOrder = ["xformOp:rotateXYZ"]
        }
        def RectLight "CeilingSoftbox"
        {
            float inputs:height = 5.0
            float inputs:width = 5.0
            float inputs:intensity = 450
            double3 xformOp:translate = (0, 0.8, 2.8)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }
    }

    def Camera "Camera"
    {
        double3 xformOp:translate = (-3.0, -2.2, 1.6)
        double3 xformOp:rotateXYZ = (62, 0, -38)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]
        float focalLength = 20
    }
}
