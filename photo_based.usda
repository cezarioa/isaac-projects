                double3 xformOp:translate = (-1.5, 2.25, 0.36)
                uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
                rel material:binding = </World/Environment/Looks/mat_black_plastic>
            }
        }

        def Xform "props"
        {
            def Xform "LargeWhiteDesk"
            {
                double3 xformOp:rotateXYZ = (0, 0, -12)
                double3 xformOp:translate = (1.15, 0.75, 0.73)
                uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateXYZ"]

                def Cube "TableTop"
